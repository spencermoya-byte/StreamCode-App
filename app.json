{
  "expo": {
    "name": "StreamCode",
    "slug": "streamcode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "streamcode",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f0e"
    },
    "ios": {
      "bundleIdentifier": "com.streamcode.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "StreamCode uses Face ID to unlock the app and protect your streaming codes."
      }
    },
    "android": {
      "package": "com.streamcode.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0f0e"
      }
    },
    "plugins": ["expo-dev-client"]
  }
}
